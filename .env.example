PORT=3000
NODE_ENV=development

# Supabase — use a SERVICE ROLE KEY (não anon key) para o backend
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=sua_service_role_key_aqui

# OpenAI — gere em https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_openai_key_aqui
# CORS — em produção, liste as origens permitidas separadas por vírgula
# Ex: https://www.inclusivaula.com.br,https://inclusivaula.com.br
ALLOWED_ORIGINS=http://localhost:5173

# Billing — Asaas (pagamentos recorrentes)
# Crie sua conta em https://www.asaas.com e gere a API Key em Configurações > Integrações
ASAAS_API_KEY=
# Token configurado no painel Asaas em Configurações > Notificações > Webhook
ASAAS_WEBHOOK_TOKEN=
# true = sandbox (testes), false = produção real
ASAAS_SANDBOX=true

# Swagger — habilite a documentação da API
SWAGGER_ENABLED=true
