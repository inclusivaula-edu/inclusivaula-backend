{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",

    "moduleResolution": "node",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "declaration": true,
    "sourceMap": true,

    "outDir": "./dist",
    "baseUrl": "./",

    "incremental": true,

    "skipLibCheck": true,
    "strict": false,

    "useDefineForClassFields": false
  },

  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts"
  ]
}